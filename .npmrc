# @strands-agents/sdk >=1.8 declares express ^5 as an OPTIONAL peer. This repo
# intentionally stays on Express 4 (Lambda Web Adapter / AgentCore both work with
# it; Express 5 migration is out of scope). npm still raises ERESOLVE when a
# present dependency mismatches an optional peer, so relax that one check here.
legacy-peer-deps=true
