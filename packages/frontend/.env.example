# Cognito Configuration
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_AWS_REGION=us-east-1

# UI-only toggle: expose the Sign Up screen and "Create account" link.
# Must be the literal string "true" to enable. This flag only changes which
# React routes render; the underlying Cognito self sign-up policy is managed
# by CDK and is NOT affected by this value.
# VITE_SELF_SIGN_UP_ENABLED=true

# Backend API Configuration
VITE_BACKEND_URL=http://localhost:3000

# Agent API Configuration
VITE_AGENT_ENDPOINT=http://localhost:8080/invocations

# AppSync Events Configuration (for real-time session updates)
# Get these values from CDK deployment output:
# - AppSyncEventsRealtimeEndpoint
VITE_APPSYNC_EVENTS_ENDPOINT=

# Development Configuration (optional)
# VITE_AGENT_ENDPOINT=https://your-gateway-id.bedrock-agentcore.us-east-1.amazonaws.com/invocations
