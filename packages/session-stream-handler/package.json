{
  "name": "@moca/session-stream-handler",
  "version": "0.1.0",
  "description": "DynamoDB Streams handler for session events, publishes to AppSync Events",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix && prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "test": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --passWithNoTests --forceExit",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --passWithNoTests --coverage",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agentcore",
    "dynamodb-streams",
    "appsync-events",
    "realtime"
  ],
  "author": "AgentCore Session Stream Handler",
  "license": "MIT",
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/credential-provider-node": "^3.750.0",
    "@smithy/signature-v4": "^4.0.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "pino-pretty": "^13.1.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
