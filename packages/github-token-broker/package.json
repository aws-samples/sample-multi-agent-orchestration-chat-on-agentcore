{
  "name": "@moca/github-token-broker",
  "version": "0.1.0",
  "description": "GitHub Token Broker Lambda — fetches a fixed GitHub PAT from Secrets Manager and returns it. Deliberately not an AgentCore Gateway Target so the agent cannot invoke it via MCP.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix && prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "test": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --passWithNoTests --forceExit",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --coverage",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "keywords": [
    "agentcore",
    "secrets-manager",
    "github"
  ],
  "author": "AgentCore GitHub Token Broker",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.685.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
