{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "inputSchema": { "type": "object" }
        }
      }
    }
  },
  "tools": [
    {
      "name": "echo",
      "description": "A tool that returns the input message as-is. Also provides message length and case conversion.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "The message string to echo"
          }
        },
        "required": ["message"],
        "additionalProperties": false
      }
    },
    {
      "name": "ping",
      "description": "A tool that performs a connectivity check for the Lambda function and retrieves system information. Returns details such as response time and memory usage.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    }
  ]
}
